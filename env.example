# --- Strava Configuration ---
# Create an app at https://developers.strava.com/
# Set Authorization Callback Domain to: localhost
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here
# Optional: defaults to http://localhost:3000/api/auth/strava/callback
# STRAVA_REDIRECT_URI=

# --- Whoop Configuration ---
# Create an app at https://developer.whoop.com/
# Set Redirect URI to: http://localhost:3000/api/auth/whoop/callback
WHOOP_CLIENT_ID=your_whoop_client_id_here
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here
# Optional: defaults to http://localhost:3000/api/auth/whoop/callback
# WHOOP_REDIRECT_URI=

# --- Gemini API Configuration ---
# Get an API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server Configuration ---
PORT=3000
